# robot-platform udev rules
#
# Grants non-root access to GPIO and I²C character devices for the ROS 2 HAL
# nodes (motor_driver, imu_driver). User must be a member of the `gpio` and
# `i2c` groups (default on Ubuntu 24.04; verify with `groups`).
#
# Install: sudo cp 99-robot-platform.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

SUBSYSTEM=="gpio", KERNEL=="gpiochip*", GROUP="gpio", MODE="0660"
KERNEL=="i2c-[0-9]*", GROUP="i2c", MODE="0660"
