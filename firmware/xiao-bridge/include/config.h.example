// Compile-time configuration for xiao_bridge.
//
// Copy this file to config.h and fill in your Wi-Fi credentials.
// config.h is gitignored — do not commit it.
//
// Per FW-XIAO §5, runtime re-config is not supported in iteration 1.
// Reflash to change settings.

#pragma once

// ----- Wi-Fi -------------------------------------------------------------

// SSID and PSK of the network the rover (and operator app) live on. The
// XIAO connects in station mode and registers itself via mDNS.
#define WIFI_SSID     "your-ssid-here"
#define WIFI_PASSWORD "your-psk-here"

// mDNS hostname. The Pi resolves this name via mavros and image_retriever
// (per ICD-XIAO-001 §4 + FW-XIAO §3) — must match those consumers.
#define MDNS_HOSTNAME "xiao-bridge"

// ----- Networking ports --------------------------------------------------

// MAVLink TCP listener; mavros connects here.
#define MAVLINK_TCP_PORT 5760

// HTTP server for /capture and /latest.jpg.
#define HTTP_PORT 80

// ----- MAVLink UART ------------------------------------------------------

// FC TELEM2 baud rate. Match the FC's SERIAL2_BAUD setting (FW-ACP).
#define MAVLINK_UART_BAUD 57600
// XIAO ESP32-S3 has multiple HW UARTs; UART1 is the default for external
// serial (UART0 is used by USB CDC for serial monitor).
#define MAVLINK_UART_RX_PIN 44   // GPIO 44 = D7 on the XIAO header
#define MAVLINK_UART_TX_PIN 43   // GPIO 43 = D6 on the XIAO header

// ----- Camera ------------------------------------------------------------

// JPEG quality on the ESP32-camera library scale: 0..63, lower = better.
// FW-XIAO §4 ships with 12.
#define CAMERA_JPEG_QUALITY 12
